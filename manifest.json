{
	"manifest_version": 3,
	"name": "GitHub Mentions+",
	"description": "Enhance GitHub @mention autocomplete by adding custom team members or external collaborators.",
	"version": "1.1.3",
	"browser_specific_settings": {
		"gecko": {
			"id": "github-mentions-plus@example.com",
			"strict_min_version": "58.0"
		}
	},
	"icons": {
		"64": "icons/icon.png"
	},
	"permissions": [
		"storage"
	],
	"host_permissions": [
		"*://*.github.com/*"
	],
	"content_scripts": [
		{
			"matches": [
				"*://*.github.com/*"
			],
			"js": [
				"utils/settings.js",
				"utils/storage.js",
				"utils/api.js",
				"utils/overlay/state.js",
				"utils/overlay/position.js",
				"utils/overlay/render.js",
				"utils/overlay/navigation.js",
				"utils/dom.js",
				"content/triggers.js",
				"content/commands.js",
				"content/users-source.js",
				"content/app.js",
				"content_script.js"
			]
		}
	],
	"background": {
		"service_worker": "background.js"
	},
	"action": {
		"default_icon": {
			"64": "icons/icon.png"
		},
		"default_popup": "browserAction/index.html",
		"default_title": "GitHub Mentions+"
	}
}
